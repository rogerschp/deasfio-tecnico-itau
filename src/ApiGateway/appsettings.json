{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "clientes-route": {
        "ClusterId": "clientes-cluster",
        "Match": {
          "Path": "/api/clientes/{**catch-all}"
        }
      },
      "clientes-internal-route": {
        "ClusterId": "clientes-cluster",
        "Match": {
          "Path": "/api/internal/clientes/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        }
      },
      "cotacao-route": {
        "ClusterId": "cotacao-cluster",
        "Match": {
          "Path": "/api/cotacoes/{**catch-all}"
        }
      },
      "motor-route": {
        "ClusterId": "motor-cluster",
        "Match": {
          "Path": "/api/motor/{**catch-all}"
        }
      },
      "rebalanceamento-route": {
        "ClusterId": "rebalanceamento-cluster",
        "Match": {
          "Path": "/api/rebalanceamento/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "clientes-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "cotacao-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "motor-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "rebalanceamento-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  }
}
